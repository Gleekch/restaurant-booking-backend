# Database
MONGODB_URI=mongodb://localhost:27017/restaurant_booking

# Backend
PORT=3000
BACKEND_URL=https://restaurant-booking-backend-y3sp.onrender.com
RESTAURANT_TIME_ZONE=Indian/Reunion
RESTAURANT_CAPACITY=70
MIDI_DURATION_MIN=90
SOIR_DURATION_MIN=120

# Internal desktop auth
API_KEY=your_api_key_here
ADMIN_USER=admin
ADMIN_PASS=your_admin_password_here

# Business rules
RESTAURANT_PHONE_DISPLAY=02 62 26 67 19
RESTAURANT_PHONE_RAW=0262266719

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=clement_bordeau@hotmail.fr
EMAIL_PASS=your_app_password

# WhatsApp Business
WHATSAPP_NUMBER=+262692123456

# Optional OpenAI config
OPENAI_API_KEY=your_openai_api_key

# Capacité en ligne (couverts max acceptés via le site, défaut 50)
ONLINE_CAPACITY=50
# Couverts max par créneau de 15 min (tolérance +2 = limite dure)
SLOT_MAX_COVERS=15
SLOT_TOLERANCE=2

# Slot recommendations (Phase 1-4 — désactivé par défaut)
# Passer à true pour activer les recommandations de créneaux enrichies
SLOT_RECOMMENDATIONS_ENABLED=false
# Passer à true après validation des données pour activer la pénalisation stricte
SLOT_BALANCING_STRICT=false
# Horaire de coupure entre vague 1 et vague 2 (format HH:MM)
SLOT_MIDI_WAVE1_CUTOFF=12:30
SLOT_SOIR_WAVE1_CUTOFF=19:15

# ─── Arrhes / acompte en ligne (Stripe) ───
# Clés Stripe (mode test: sk_test_… / whsec_…  | prod: sk_live_…)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# Interrupteur global: false = aucun acompte demandé (désactive tout le système)
DEPOSIT_ENABLED=true
# Acompte exigé à partir de ce nombre de couverts
DEPOSIT_MIN_PARTY=6
# Montant de l'acompte par personne, en centimes (1000 = 10,00 €)
DEPOSIT_PER_PERSON_CENTS=1000
DEPOSIT_CURRENCY=eur
# Délai avant la réservation en deçà duquel l'acompte n'est plus remboursé (heures)
DEPOSIT_CANCELLATION_HOURS=24
# Durée de validité de la page de paiement Stripe (minutes, min 30 / max 1440)
CHECKOUT_EXPIRY_MINUTES=30
# URL publique du site (pour les redirections de retour Stripe)
PUBLIC_SITE_URL=https://www.aumurmuredesflots.com
